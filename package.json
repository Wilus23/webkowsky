{
  "name": "webkowsky-site",
  "version": "0.10.0",
  "private": true,
  "description": "Next.js + Sanity: A Powerful Website Starter with Real-time Visual Editing",
  "repository": {
    "type": "git",
    "url": "https://github.com/Wilus23/webkowsky.git"
  },
  "keywords": [
    "Sanity",
    "Next.js",
    "Headless CMS",
    "Visual Editing",
    "Live Content API (LCAPI)",
    "Real-time"
  ],
  "homepage": "https://github.com/sanity-io/sanity-template-nextjs-clean#readme",
  "bugs": {
    "url": "https://github.com/sanity-io/sanity-template-nextjs-clean/issues"
  },
  "workspaces": [
    "studio",
    "frontend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel --print-label dev:*",
    "dev:next": "npm run dev --workspace=frontend",
    "dev:studio": "npm run dev --workspace=studio",
    "format": "prettier --cache --write .",
    "import-sample-data": "cd studio && sanity dataset import sample-data.tar.gz --replace",
    "lint": "npm run lint --workspace=frontend",
    "release:preview:patch": "node ./scripts/release.mjs preview patch",
    "release:preview:minor": "node ./scripts/release.mjs preview minor",
    "release:preview:major": "node ./scripts/release.mjs preview major",
    "release:patch": "node ./scripts/release.mjs stable patch",
    "release:minor": "node ./scripts/release.mjs stable minor",
    "release:major": "node ./scripts/release.mjs stable major",
    "type-check": "npm run type-check --workspaces"
  },
  "engines": {
    "node": ">=20.19.0 <21 || >=22.12.0",
    "npm": ">=10"
  },
  "prettier": "@sanity/prettier-config",
  "devDependencies": {
    "@sanity/prettier-config": "^2.0.2",
    "npm-run-all2": "^5.0.2",
    "prettier": "^3.7.3"
  }
}
